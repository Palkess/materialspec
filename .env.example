# ─── Postgres (main) ───────────────────────────────────────────
POSTGRES_USER=materialspec
POSTGRES_PASSWORD=materialspec
POSTGRES_DB=materialspec
DATABASE_URL=postgresql://materialspec:materialspec@postgres:5432/materialspec

# ─── Postgres (test) ──────────────────────────────────────────
POSTGRES_TEST_USER=materialspec_test
POSTGRES_TEST_PASSWORD=materialspec_test
POSTGRES_TEST_DB=materialspec_test
DATABASE_TEST_URL=postgresql://materialspec_test:materialspec_test@postgres-test:5433/materialspec_test

# ─── API ──────────────────────────────────────────────────────
API_PORT=3721
API_HOST=0.0.0.0
API_HOST_PORT=3721
SESSION_SECRET=change-me-to-a-random-64-char-string

# ─── Admin seed ───────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=change-me-on-first-login

# ─── Web ──────────────────────────────────────────────────────
PUBLIC_API_URL=http://localhost:3721
