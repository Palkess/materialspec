---
import svCommon from "../../../../packages/shared/i18n/sv/common.json";
import enCommon from "../../../../packages/shared/i18n/en/common.json";

interface Props {
  title: string;
  lang: "sv" | "en";
}

const { title, lang } = Astro.props;
const otherLang = lang === "sv" ? "en" : "sv";
const currentPath = Astro.url.pathname.replace(`/${lang}/`, `/${otherLang}/`);
const t = lang === "sv" ? svCommon : enCommon;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Materialspec</title>
  </head>
  <body class="min-h-screen bg-concrete-950 text-neutral-100 font-sans">
    <header class="border-b border-concrete-800 bg-concrete-900 px-6 py-3 flex items-center justify-between">
      <div class="flex items-center gap-6">
        <a href={`/${lang}/specs`} class="text-xl font-bold tracking-tight text-safety-500 uppercase">
          Materialspec
        </a>
        <nav class="hidden sm:flex items-center gap-1">
          <a href={`/${lang}/specs`} class="text-sm px-3 py-2 rounded text-neutral-200 hover:bg-concrete-800 hover:text-white font-bold uppercase tracking-wide transition-colors">
            {t.specs}
          </a>
        </nav>
      </div>
      <div class="flex items-center gap-2">
        <a
          href={currentPath}
          class="min-h-btn inline-flex items-center px-3 py-2 rounded bg-concrete-800 hover:bg-concrete-700 text-sm text-neutral-200 hover:text-white font-bold uppercase tracking-wide transition-colors"
        >
          {lang === "sv" ? t.switchToEnglish : t.switchToSwedish}
        </a>
        <a
          href={`/${lang}/account`}
          class="min-h-btn inline-flex items-center px-4 py-2 bg-concrete-800 hover:bg-concrete-700 text-sm text-neutral-200 hover:text-white rounded font-bold uppercase tracking-wide transition-colors"
        >
          {t.account}
        </a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline define:vars={{ apiUrl: import.meta.env.PUBLIC_API_URL || "http://localhost:3002" }}>
      window.__API_URL__ = apiUrl;
    </script>
  </body>
</html>
